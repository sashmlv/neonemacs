    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "typescript": "^5.9.3"
  }
}
