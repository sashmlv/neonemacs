{
  "name": "shell-mcp",
  "version": "1.0.0",
  "main": "dist",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist",
    "nodemon": "nodemon --config nodemon.json",
    "test": "npm run build && node --enable-source-maps --test dist/test/*.test.js",
    "watch": "tsc -b -w tsconfig.json",
    "dev": "npm run build && concurrently -n tsc,srv \"npm run watch\" \"npm run nodemon\""
